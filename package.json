{
  "name": "multibot",
  "version": "0.1.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/codance-ai/multibot.git"
  },
  "homepage": "https://github.com/codance-ai/multibot",
  "bugs": {
    "url": "https://github.com/codance-ai/multibot/issues"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "npm run build:dashboard && npm run deploy:worker",
    "deploy:worker": "wrangler deploy",
    "deploy:dashboard": "cd dashboard && npm install && npm run build",
    "build:dashboard": "cd dashboard && npm run build:fast",
    "typecheck": "cd dashboard && npx tsc -b",
    "types": "wrangler types",
    "backfill:trace-index": "node scripts/backfill-request-trace-index.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai": "^3.0.41",
    "@mozilla/readability": "^0.6.0",
    "agents": "^0.8.0",
    "ai": "^6.0.116",
    "fflate": "^0.8.2",
    "jose": "^6.1.3",
    "linkedom": "^0.18.12",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260307.1",
    "htmlrewriter": "^0.0.13",
    "typescript": "^5.7",
    "vitest": "^3.2.4",
    "wrangler": "^4.0"
  }
}
